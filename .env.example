#
# REYAD HASNAIN — Environment variables
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` for local dev.
# In production, set these in the Vercel dashboard:
#   Project → Settings → Environment Variables
# Mark each one for: Production, Preview, Development (all three).
#

# ─── Public ──────────────────────────────────────────────────────────────
# Canonical site URL — used in <link rel="canonical">, sitemap, OG meta,
# JSON-LD, and the contact auto-reply email.
# In Vercel, set this to your custom domain once it's wired.
PUBLIC_SITE_URL=https://reyadhasnain.com

# ─── SMTP credentials ────────────────────────────────────────────────────
# Used by /api/contact via Nodemailer.
#
# Recommended providers (all work with this code, no changes needed):
#   • Gmail App Password  — easiest, free, fine for personal volume.
#       1. Enable 2-Step Verification on your Gmail account.
#       2. Visit https://myaccount.google.com/apppasswords
#       3. Generate a 16-char app password and paste it as SMTP_PASS.
#       SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
#
#   • Brevo (Sendinblue) — 300 emails/day free, better deliverability.
#       SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  SMTP_SECURE=false
#
#   • Zoho Mail — if you already use Zoho for the smart-lab.biz domain.
#       SMTP_HOST=smtp.zoho.com  SMTP_PORT=465  SMTP_SECURE=true
#
#   • AWS SES SMTP — cheapest at scale, requires sandbox approval.
#       SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=465  SMTP_SECURE=true
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-16-char-app-password

# ─── Mail routing ────────────────────────────────────────────────────────
# Where contact-form messages land.
MAIL_TO=reyad@smart-lab.biz

# What the From: header reads. Must be authorised by your SMTP provider.
# For Gmail this should be your Gmail address (or a verified alias).
# For Brevo / SES, this can be any verified sender on your domain.
MAIL_FROM="Reyad Hasnain Website <noreply@reyadhasnain.com>"

# Per-IP submission cap (per minute). Defends the form from spam loops.
RATE_LIMIT_PER_MIN=5
