# Astro 6 + alpha integrations have peer-deps that target Astro 7 (their next major).
# They work correctly against Astro 6.2 at runtime — only the install-time peer
# check fails. This setting tells npm to install anyway, like every other npm
# install command in this project's history has been doing manually.
legacy-peer-deps=true

# Quieter installs.
audit=false
fund=false
