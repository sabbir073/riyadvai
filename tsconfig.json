{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "verbatimModuleSyntax": false,
    "allowJs": true,
    "ignoreDeprecations": "6.0"
  }
}
