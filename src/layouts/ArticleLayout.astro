---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { formatDate, readingTime } from '~/lib/format';
import { articleSchema } from '~/lib/seo';
import { ArrowLeft, Calendar, Clock } from 'lucide-react';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags?: string[];
  cover?: string;
  rawText?: string;
  path: string;
}

const { title, description, publishedAt, updatedAt, tags = [], cover, rawText, path } = Astro.props;

const minutes = rawText ? readingTime(rawText) : 4;
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  type="article"
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  image={cover}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Insights', href: '/insights' },
    { label: title, href: path },
  ]}
  jsonLd={[
    articleSchema({
      title,
      description,
      publishedAt,
      updatedAt,
      url: path,
      image: cover,
    }),
  ]}
>
  <article class="page-x relative pt-32">
    <div class="mx-auto max-w-3xl">
      <a
        href="/insights"
        class="inline-flex items-center gap-2 text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--accent-cyan)]"
      >
        <ArrowLeft className="h-4 w-4" />
        All insights
      </a>

      <header class="mt-10 flex flex-col gap-6">
        {tags.length > 0 && (
          <div class="flex flex-wrap items-center gap-2">
            {tags.map((t) => (
              <span class="rounded-full border border-[var(--border-hair)] bg-[var(--bg-glass)] px-3 py-1 text-xs font-medium uppercase tracking-widest text-[var(--accent-cyan)] backdrop-blur">
                {t}
              </span>
            ))}
          </div>
        )}

        <h1 class="text-balance font-sans text-4xl font-semibold leading-[1.05] tracking-tight md:text-6xl">
          {title}
        </h1>

        <p class="text-pretty text-[var(--text-lead)] leading-relaxed text-[var(--text-muted)]">
          {description}
        </p>

        <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--text-muted)]">
          <span class="inline-flex items-center gap-2">
            <Calendar className="h-4 w-4" />
            <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
          </span>
          <span aria-hidden>·</span>
          <span class="inline-flex items-center gap-2">
            <Clock className="h-4 w-4" />
            {minutes} min read
          </span>
        </div>
      </header>

      {cover && (
        <figure class="mt-12 overflow-hidden rounded-3xl border border-[var(--border-hair)]">
          <img src={cover} alt="" class="aspect-[16/9] w-full object-cover" />
        </figure>
      )}

      <div
        class="prose prose-invert mt-12 max-w-none text-pretty text-[var(--text-primary)]"
      >
        <div class="dropcap article-prose font-serif text-[1.18rem] leading-[1.75] text-[var(--text-primary)]/95">
          <slot />
        </div>
      </div>

      <footer class="mt-16 flex flex-col gap-4 border-t border-[var(--border-hair)] pt-8 text-sm text-[var(--text-muted)]">
        <p>
          Have a thought? Disagree? <a
            href="/contact"
            class="text-[var(--accent-cyan)] underline-offset-4 hover:underline"
          >Email Reyad directly</a>.
        </p>
      </footer>
    </div>
  </article>

  <style>
    .article-prose :global(h2) {
      font-family: var(--font-sans);
      font-style: normal;
      font-size: 2rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-top: 3rem;
      margin-bottom: 1rem;
    }
    .article-prose :global(h3) {
      font-family: var(--font-sans);
      font-style: normal;
      font-size: 1.5rem;
      font-weight: 600;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
    }
    .article-prose :global(p) {
      margin-bottom: 1.5rem;
    }
    .article-prose :global(p + p) {
      margin-top: 0;
    }
    .article-prose :global(strong) {
      font-style: normal;
      color: var(--text-primary);
      font-weight: 600;
    }
    .article-prose :global(a) {
      color: var(--accent-cyan);
      text-underline-offset: 4px;
      text-decoration: underline;
      text-decoration-thickness: 1px;
    }
    .article-prose :global(blockquote) {
      border-left: 2px solid var(--accent-cyan);
      padding-left: 1.5rem;
      margin-block: 2rem;
      font-size: 1.4rem;
      line-height: 1.4;
      color: var(--text-primary);
    }
    .article-prose :global(ul),
    .article-prose :global(ol) {
      margin: 1.5rem 0;
      padding-left: 1.5rem;
    }
    .article-prose :global(li) {
      margin-bottom: 0.5rem;
    }
    .article-prose :global(code) {
      font-family: var(--font-mono);
      font-size: 0.9em;
      background: var(--bg-elevated);
      padding: 0.15em 0.4em;
      border-radius: 4px;
    }
  </style>
</BaseLayout>
