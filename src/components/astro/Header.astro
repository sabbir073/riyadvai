---
import { NAV, PERSON } from '~/data/site';
import ThemeToggle from '~/components/react/ThemeToggle';

const path = Astro.url.pathname;
---

<header
  class="fixed inset-x-0 top-0 z-50 transition-[backdrop-filter,background] duration-300"
  data-header
>
  <div class="absolute inset-0 -z-10 backdrop-blur-md" data-header-bg></div>

  <div class="page-x mx-auto flex h-16 max-w-7xl items-center justify-between gap-4">
    <a
      href="/"
      class="group inline-flex items-center gap-2 text-base font-semibold tracking-tight"
      aria-label={`${PERSON.fullName} — Home`}
    >
      <span
        class="relative grid h-9 w-9 place-items-center rounded-full border border-[var(--border-hair)] bg-[var(--bg-elevated)] text-sm font-bold text-[var(--brand)]"
      >
        RH
        <span
          class="absolute inset-0 rounded-full opacity-0 ring-1 ring-[var(--brand)] transition-opacity duration-500 group-hover:opacity-100"
        ></span>
      </span>
      <span class="hidden sm:inline">
        Reyad Hasnain
      </span>
    </a>

    <nav aria-label="Primary" class="hidden lg:block">
      <ul class="flex items-center gap-1">
        {
          NAV.slice(0, 6).map((item) => {
            const active = path === item.href || (item.href !== '/' && path.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'relative rounded-full px-3 py-1.5 text-sm transition-colors duration-200',
                    active
                      ? 'text-[var(--text-primary)]'
                      : 'text-[var(--text-muted)] hover:text-[var(--text-primary)]',
                  ]}
                  aria-current={active ? 'page' : undefined}
                >
                  {item.label}
                  {active && (
                    <span
                      aria-hidden
                      class="absolute inset-x-3 -bottom-px h-px bg-gradient-to-r from-transparent via-[var(--brand)] to-transparent"
                    ></span>
                  )}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle client:load />
      <a
        href="/contact"
        class="relative hidden h-9 items-center overflow-hidden rounded-full px-4 text-sm font-medium text-white shadow-[0_10px_30px_-10px_var(--brand)] transition-all hover:-translate-y-px hover:shadow-[0_15px_35px_-10px_var(--brand)] sm:inline-flex"
        style={`background: ${'var(--brand-gradient)'};`}
      >
        Get in touch
      </a>
      <button
        type="button"
        aria-label="Open menu"
        class="grid h-9 w-9 place-items-center rounded-full border border-[var(--border-hair)] bg-[var(--bg-glass)] backdrop-blur lg:hidden"
        data-mobile-toggle
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    data-mobile-panel
    class="invisible absolute inset-x-3 top-[4.25rem] origin-top scale-95 rounded-2xl border border-[var(--border-hair)] bg-[var(--bg-elevated)] p-4 opacity-0 shadow-[var(--shadow-card)] backdrop-blur-xl transition lg:hidden"
  >
    <ul class="flex flex-col gap-1">
      {
        NAV.map((item) => {
          const active = path === item.href || (item.href !== '/' && path.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block rounded-lg px-3 py-2 text-sm transition-colors',
                  active
                    ? 'bg-[var(--bg-glass)] text-[var(--text-primary)]'
                    : 'text-[var(--text-muted)] hover:bg-[var(--bg-glass)] hover:text-[var(--text-primary)]',
                ]}
                aria-current={active ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</header>

<script>
  // Re-binds on every page navigation so it survives Astro's <ClientRouter />
  // swapping out the DOM. Pattern: name a setup fn, call it once now, and
  // call it again on every astro:page-load.
  const setupHeader = () => {
    const header = document.querySelector<HTMLElement>('[data-header]');
    const headerBg = document.querySelector<HTMLElement>('[data-header-bg]');
    const mobileToggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
    const mobilePanel = document.querySelector<HTMLElement>('[data-mobile-panel]');

    if (!header || !mobileToggle || !mobilePanel) return;

    // Scroll-state header (translucent → opaque background)
    const onScroll = () => {
      const y = window.scrollY;
      header.dataset.scrolled = y > 8 ? 'true' : 'false';
      if (headerBg) {
        headerBg.style.background = y > 8 ? 'color-mix(in oklch, var(--bg-base) 78%, transparent)' : 'transparent';
        headerBg.style.borderBottom = y > 8 ? '1px solid var(--border-hair)' : '1px solid transparent';
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // Mobile drawer
    let open = false;
    const setOpen = (v: boolean) => {
      open = v;
      mobilePanel.classList.toggle('invisible', !v);
      mobilePanel.classList.toggle('opacity-0', !v);
      mobilePanel.classList.toggle('scale-95', !v);
      mobilePanel.classList.toggle('opacity-100', v);
      mobilePanel.classList.toggle('scale-100', v);
      mobileToggle.setAttribute('aria-expanded', v ? 'true' : 'false');
      document.body.style.overflow = v ? 'hidden' : '';
    };

    mobileToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(!open);
    });

    // Close when a nav link is clicked
    mobilePanel.querySelectorAll<HTMLAnchorElement>('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!open) return;
      const t = e.target as Node;
      if (!mobilePanel.contains(t) && !mobileToggle.contains(t)) setOpen(false);
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) setOpen(false);
    });
  };

  setupHeader();
  document.addEventListener('astro:page-load', setupHeader);
</script>
