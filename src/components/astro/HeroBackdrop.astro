---
// Pure-SVG / pure-CSS animated hero backdrop.
// Renders an orbital network — concentric rings, drifting nodes, signal pulses, fiber paths.
// Zero JS. Respects prefers-reduced-motion. Works in every browser, ships ~3kb gzipped.
---

<div class="hero-backdrop" aria-hidden="true">
  <!-- Aurora gradient base -->
  <div class="hero-aurora"></div>

  <!-- Animated mesh blobs (CSS) -->
  <div class="hero-blob hero-blob--1"></div>
  <div class="hero-blob hero-blob--2"></div>
  <div class="hero-blob hero-blob--3"></div>

  <!-- Orbital network SVG -->
  <svg
    class="hero-svg"
    viewBox="0 0 1200 800"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid slice"
  >
    <defs>
      <linearGradient id="ring-grad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="oklch(0.7 0.2 41)" stop-opacity="0.5" />
        <stop offset="50%" stop-color="oklch(0.7 0.2 41)" stop-opacity="0.05" />
        <stop offset="100%" stop-color="oklch(0.82 0.13 85)" stop-opacity="0.3" />
      </linearGradient>
      <radialGradient id="node-glow">
        <stop offset="0%" stop-color="oklch(0.7 0.2 41)" stop-opacity="0.85" />
        <stop offset="100%" stop-color="oklch(0.7 0.2 41)" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="line-grad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="oklch(0.7 0.2 41)" stop-opacity="0" />
        <stop offset="50%" stop-color="oklch(0.7 0.2 41)" stop-opacity="0.6" />
        <stop offset="100%" stop-color="oklch(0.7 0.2 41)" stop-opacity="0" />
      </linearGradient>
      <filter id="soft-glow">
        <feGaussianBlur stdDeviation="4" />
      </filter>
    </defs>

    <!-- Concentric orbital rings (rotated in 3D feel) -->
    <g transform="translate(600 400)" class="hero-orbits">
      <ellipse cx="0" cy="0" rx="540" ry="180" fill="none" stroke="url(#ring-grad)" stroke-width="1" />
      <ellipse cx="0" cy="0" rx="440" ry="140" fill="none" stroke="url(#ring-grad)" stroke-width="1" opacity="0.7" />
      <ellipse cx="0" cy="0" rx="340" ry="100" fill="none" stroke="url(#ring-grad)" stroke-width="1" opacity="0.5" />
      <ellipse cx="0" cy="0" rx="240" ry="70" fill="none" stroke="url(#ring-grad)" stroke-width="1" opacity="0.35" />

      <ellipse cx="0" cy="0" rx="540" ry="540" fill="none" stroke="url(#ring-grad)" stroke-width="0.7" opacity="0.3" transform="rotate(60)" />
      <ellipse cx="0" cy="0" rx="540" ry="540" fill="none" stroke="url(#ring-grad)" stroke-width="0.7" opacity="0.3" transform="rotate(-60)" />
    </g>

    <!-- Orbiting nodes -->
    <g transform="translate(600 400)" class="hero-orbit-spin">
      <g transform="translate(540 0)">
        <circle r="42" fill="url(#node-glow)" />
        <circle r="3.5" fill="oklch(0.7 0.2 41)" />
      </g>
      <g transform="translate(-380 -100)">
        <circle r="32" fill="url(#node-glow)" opacity="0.7" />
        <circle r="2.5" fill="oklch(0.82 0.13 85)" />
      </g>
      <g transform="translate(280 110)">
        <circle r="28" fill="url(#node-glow)" opacity="0.6" />
        <circle r="2.5" fill="oklch(0.7 0.2 41)" />
      </g>
    </g>

    <g transform="translate(600 400)" class="hero-orbit-spin-reverse">
      <g transform="translate(-440 70)">
        <circle r="36" fill="url(#node-glow)" opacity="0.8" />
        <circle r="3" fill="oklch(0.7 0.22 340)" />
      </g>
      <g transform="translate(180 -120)">
        <circle r="24" fill="url(#node-glow)" opacity="0.5" />
        <circle r="2" fill="oklch(0.7 0.2 41)" />
      </g>
    </g>

    <!-- Fixed network nodes -->
    <g class="hero-nodes">
      <circle cx="160" cy="180" r="3" fill="oklch(0.7 0.2 41)" />
      <circle cx="160" cy="180" r="20" fill="url(#node-glow)" />
      <circle cx="980" cy="120" r="2.5" fill="oklch(0.82 0.13 85)" />
      <circle cx="980" cy="120" r="14" fill="url(#node-glow)" />
      <circle cx="1080" cy="640" r="3" fill="oklch(0.7 0.22 340)" />
      <circle cx="1080" cy="640" r="18" fill="url(#node-glow)" />
      <circle cx="120" cy="660" r="2.5" fill="oklch(0.7 0.2 41)" />
      <circle cx="120" cy="660" r="14" fill="url(#node-glow)" />
    </g>

    <!-- Signal pulse lines -->
    <g class="hero-signals">
      <line x1="160" y1="180" x2="600" y2="400" stroke="url(#line-grad)" stroke-width="1.2" stroke-dasharray="4 8" class="hero-signal hero-signal--1" />
      <line x1="980" y1="120" x2="600" y2="400" stroke="url(#line-grad)" stroke-width="1.2" stroke-dasharray="4 8" class="hero-signal hero-signal--2" />
      <line x1="1080" y1="640" x2="600" y2="400" stroke="url(#line-grad)" stroke-width="1.2" stroke-dasharray="4 8" class="hero-signal hero-signal--3" />
      <line x1="120" y1="660" x2="600" y2="400" stroke="url(#line-grad)" stroke-width="1.2" stroke-dasharray="4 8" class="hero-signal hero-signal--4" />
    </g>

    <!-- Center hub -->
    <g transform="translate(600 400)">
      <circle r="60" fill="url(#node-glow)" opacity="0.55" />
      <circle r="36" fill="url(#node-glow)" opacity="0.7" />
      <circle r="6" fill="oklch(0.96 0.005 250)" filter="url(#soft-glow)" />
      <circle r="3" fill="white" />
    </g>

    <!-- Drifting particles -->
    <g class="hero-particles">
      <circle cx="220" cy="320" r="1.5" fill="oklch(0.7 0.2 41)" class="hero-particle hero-particle--1" />
      <circle cx="900" cy="500" r="1.2" fill="oklch(0.82 0.13 85)" class="hero-particle hero-particle--2" />
      <circle cx="380" cy="700" r="1.3" fill="oklch(0.7 0.22 340)" class="hero-particle hero-particle--3" />
      <circle cx="780" cy="240" r="1.4" fill="oklch(0.7 0.2 41)" class="hero-particle hero-particle--4" />
      <circle cx="500" cy="620" r="1.2" fill="oklch(0.82 0.13 85)" class="hero-particle hero-particle--5" />
      <circle cx="1000" cy="380" r="1.3" fill="oklch(0.7 0.2 41)" class="hero-particle hero-particle--6" />
    </g>
  </svg>
</div>

<style>
  .hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-aurora {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%, color-mix(in oklch, var(--brand) 22%, transparent), transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 90%, color-mix(in oklch, var(--accent-gold) 14%, transparent), transparent 55%),
      radial-gradient(ellipse 50% 40% at 15% 75%, color-mix(in oklch, var(--accent-magenta) 12%, transparent), transparent 50%);
    pointer-events: none;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    animation: float 22s ease-in-out infinite;
    /* GPU-layer the blob so its keyframe transforms never trigger paint or
       layout on the rest of the section. Kills the CLS attribution Lighthouse
       was previously flagging on .hero-blob. */
    will-change: transform, opacity;
    transform: translateZ(0);
    backface-visibility: hidden;
    contain: layout paint;
  }

  .hero-blob--1 {
    width: 420px;
    height: 420px;
    top: 10%;
    left: 8%;
    background: radial-gradient(circle, var(--brand), transparent 70%);
    animation-duration: 28s;
  }

  .hero-blob--2 {
    width: 380px;
    height: 380px;
    bottom: 10%;
    right: 8%;
    background: radial-gradient(circle, var(--accent-gold), transparent 70%);
    animation-duration: 32s;
    animation-delay: -10s;
  }

  .hero-blob--3 {
    width: 320px;
    height: 320px;
    top: 50%;
    left: 60%;
    background: radial-gradient(circle, var(--accent-magenta), transparent 70%);
    animation-duration: 26s;
    animation-delay: -18s;
    opacity: 0.35;
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(60px, -40px) scale(1.08);
    }
    66% {
      transform: translate(-40px, 60px) scale(0.95);
    }
  }

  .hero-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.85;
  }

  .hero-orbits {
    transform-origin: center;
    animation: tilt 20s ease-in-out infinite;
  }

  @keyframes tilt {
    0%, 100% { transform: translate(600px, 400px) rotate3d(1, 0.3, 0, 0deg); }
    50% { transform: translate(600px, 400px) rotate3d(1, 0.3, 0, 8deg); }
  }

  .hero-orbit-spin {
    transform-origin: center;
    transform-box: fill-box;
    animation: spin 50s linear infinite;
  }

  .hero-orbit-spin-reverse {
    transform-origin: center;
    transform-box: fill-box;
    animation: spin 65s linear infinite reverse;
  }

  @keyframes spin {
    from { transform: translate(600px, 400px) rotate(0deg); }
    to { transform: translate(600px, 400px) rotate(360deg); }
  }

  .hero-nodes circle {
    animation: pulse-node 4s ease-in-out infinite;
  }
  .hero-nodes circle:nth-child(2) { animation-delay: -1s; }
  .hero-nodes circle:nth-child(3) { animation-delay: -2s; }
  .hero-nodes circle:nth-child(4) { animation-delay: -3s; }

  @keyframes pulse-node {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .hero-signal {
    stroke-dashoffset: 0;
    animation: dash 6s linear infinite;
  }
  .hero-signal--2 { animation-delay: -1.5s; animation-duration: 7s; }
  .hero-signal--3 { animation-delay: -3s; animation-duration: 5.5s; }
  .hero-signal--4 { animation-delay: -4.5s; animation-duration: 6.5s; }

  @keyframes dash {
    to { stroke-dashoffset: -240; }
  }

  .hero-particle {
    animation: drift 14s ease-in-out infinite;
    transform-box: fill-box;
  }
  .hero-particle--1 { animation-duration: 18s; }
  .hero-particle--2 { animation-duration: 22s; animation-delay: -3s; }
  .hero-particle--3 { animation-duration: 16s; animation-delay: -6s; }
  .hero-particle--4 { animation-duration: 20s; animation-delay: -9s; }
  .hero-particle--5 { animation-duration: 24s; animation-delay: -2s; }
  .hero-particle--6 { animation-duration: 17s; animation-delay: -7s; }

  @keyframes drift {
    0%, 100% { transform: translate(0, 0); opacity: 0.4; }
    50% { transform: translate(20px, -30px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-blob,
    .hero-orbits,
    .hero-orbit-spin,
    .hero-orbit-spin-reverse,
    .hero-nodes circle,
    .hero-signal,
    .hero-particle {
      animation: none !important;
    }
  }
</style>
