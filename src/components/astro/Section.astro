---
import { cn } from '~/lib/cn';

interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  intro?: string;
  align?: 'left' | 'center';
  contain?: boolean;
  class?: string;
}

const { id, eyebrow, title, intro, align = 'left', contain = true, class: className } = Astro.props;
---

<section id={id} class={cn('section-y page-x relative', className)}>
  <div class:list={[contain && 'mx-auto max-w-7xl']}>
    {(eyebrow || title || intro) && (
      <header
        class:list={[
          'mb-12 flex flex-col gap-4',
          align === 'center' && 'mx-auto max-w-2xl text-center items-center',
        ]}
      >
        {eyebrow && (
          <span class="enter inline-flex items-center gap-2 rounded-full border border-[var(--border-hair)] bg-[var(--bg-glass)] px-3 py-1 text-xs font-medium uppercase tracking-widest text-[var(--accent-cyan)] backdrop-blur">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--accent-cyan)]"></span>
            {eyebrow}
          </span>
        )}
        {title && (
          <h2 class="enter text-balance text-[var(--text-headline)] font-semibold tracking-tight text-[var(--text-primary)]">
            {title}
          </h2>
        )}
        {intro && (
          <p class="enter max-w-2xl text-pretty text-[var(--text-lead)] leading-relaxed text-[var(--text-muted)]">
            {intro}
          </p>
        )}
      </header>
    )}
    <slot />
  </div>
</section>
