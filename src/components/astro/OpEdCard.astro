---
import type { CollectionEntry } from 'astro:content';
import { ArrowUpRight } from 'lucide-react';
import { formatDate } from '~/lib/format';

interface Props {
  entry: CollectionEntry<'opEds'>;
  size?: 'sm' | 'md' | 'lg';
}

const { entry, size = 'md' } = Astro.props;
const { title, outlet, publishedAt, teaser, pullQuote, externalUrl } = entry.data;
const year = new Date(publishedAt).getFullYear();
---

<article
  class:list={[
    'group glass border-gradient relative flex flex-col gap-4 overflow-hidden rounded-3xl p-6 transition-transform duration-500 hover:-translate-y-1',
    size === 'lg' && 'md:p-10',
    size === 'sm' && 'p-5',
  ]}
>
  <a
    href={externalUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="absolute inset-0 z-10"
    aria-label={`Read “${title}” at ${outlet}`}
  ></a>

  <div class="flex items-center justify-between">
    <span class="text-xs font-medium uppercase tracking-widest text-[var(--accent-cyan)]">
      {outlet}
    </span>
    <time
      datetime={new Date(publishedAt).toISOString()}
      class="font-mono text-xs text-[var(--text-faint)]"
    >
      {formatDate(publishedAt)}
    </time>
  </div>

  <h3
    class:list={[
      'font-serif italic text-balance leading-tight text-[var(--text-primary)] transition-colors group-hover:text-[var(--accent-cyan)]',
      size === 'lg' ? 'text-4xl md:text-5xl' : size === 'sm' ? 'text-xl' : 'text-2xl md:text-3xl',
    ]}
  >
    {title}
  </h3>

  {pullQuote && size === 'lg' && (
    <p class="text-pretty text-[var(--text-lead)] text-[var(--text-muted)] leading-relaxed">
      {pullQuote}
    </p>
  )}

  <p class:list={['text-pretty leading-relaxed text-[var(--text-muted)]', size === 'sm' && 'text-sm']}>
    {teaser}
  </p>

  <div class="mt-auto flex items-center justify-between pt-4">
    <span class="font-mono text-xs text-[var(--text-faint)]">{year}</span>
    <span
      class="inline-flex items-center gap-1 text-sm font-medium text-[var(--text-muted)] transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-[var(--accent-cyan)]"
    >
      Read at {outlet}
      <ArrowUpRight className="h-4 w-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
    </span>
  </div>

  <div
    aria-hidden
    class="pointer-events-none absolute -right-20 -top-20 h-40 w-40 rounded-full bg-[var(--accent-cyan-soft)] blur-3xl transition-opacity duration-500 group-hover:opacity-100"
    style="opacity: 0.4"
  ></div>
</article>
