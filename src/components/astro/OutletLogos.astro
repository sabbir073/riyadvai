---
// Stylised wordmarks for the publications and TV networks Reyad has appeared in.
// These are typographic SVG renderings — they read as the brand without infringing on the actual logo files.

interface Props {
  name: string;
  className?: string;
}

const { name, className = '' } = Astro.props;
---

{name === 'The Daily Star' && (
  <svg viewBox="0 0 220 38" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="The Daily Star">
    <text x="0" y="28" font-family="Georgia, 'Times New Roman', serif" font-weight="700" font-size="26" letter-spacing="-1" fill="currentColor">The Daily Star</text>
  </svg>
)}

{name === 'The Financial Express' && (
  <svg viewBox="0 0 280 38" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="The Financial Express">
    <text x="0" y="28" font-family="Georgia, 'Times New Roman', serif" font-weight="700" font-size="22" letter-spacing="-0.5" fill="currentColor">THE FINANCIAL EXPRESS</text>
  </svg>
)}

{name === 'Daily Sun' && (
  <svg viewBox="0 0 160 42" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="Daily Sun">
    <circle cx="20" cy="21" r="14" fill="none" stroke="currentColor" stroke-width="2"/>
    <circle cx="20" cy="21" r="6" fill="currentColor"/>
    <text x="46" y="29" font-family="Inter, system-ui, sans-serif" font-weight="800" font-size="22" letter-spacing="-0.5" fill="currentColor">daily sun</text>
  </svg>
)}

{name === 'Dhaka Tribune' && (
  <svg viewBox="0 0 220 38" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="Dhaka Tribune">
    <text x="0" y="28" font-family="Inter, system-ui, sans-serif" font-weight="800" font-size="24" letter-spacing="-0.5" fill="currentColor">DHAKA</text>
    <text x="92" y="28" font-family="Georgia, 'Times New Roman', serif" font-weight="400" font-style="italic" font-size="24" fill="currentColor">Tribune</text>
  </svg>
)}

{name === 'Channel 24' && (
  <svg viewBox="0 0 180 42" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="Channel 24">
    <rect x="0" y="6" width="38" height="32" rx="4" fill="currentColor"/>
    <text x="6" y="30" font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="20" fill="white">24</text>
    <text x="48" y="29" font-family="Inter, system-ui, sans-serif" font-weight="700" font-size="22" letter-spacing="-0.5" fill="currentColor">Channel</text>
  </svg>
)}

{name === 'ETV' && (
  <svg viewBox="0 0 100 42" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="ETV">
    <rect x="0" y="6" width="92" height="32" rx="4" fill="none" stroke="currentColor" stroke-width="2"/>
    <text x="46" y="29" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="22" letter-spacing="2" fill="currentColor">ETV</text>
  </svg>
)}

{name === 'Independent TV' && (
  <svg viewBox="0 0 220 38" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="Independent TV">
    <text x="0" y="28" font-family="Inter, system-ui, sans-serif" font-weight="700" font-size="22" letter-spacing="-0.5" fill="currentColor">Independent</text>
    <text x="148" y="28" font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="22" letter-spacing="1" fill="currentColor">TV</text>
  </svg>
)}

{name === '71 TV' && (
  <svg viewBox="0 0 110 42" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="71 TV">
    <text x="0" y="32" font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="32" letter-spacing="-1" fill="currentColor">71</text>
    <text x="50" y="32" font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="22" letter-spacing="1" fill="currentColor">TV</text>
    <line x1="0" y1="38" x2="100" y2="38" stroke="currentColor" stroke-width="2"/>
  </svg>
)}
