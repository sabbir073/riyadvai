---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/astro/Section.astro';
import FilterableThoughtGrid, { type ThoughtItem } from '~/components/react/FilterableThoughtGrid';
import { OUTLETS } from '~/data/site';
import Marquee from '~/components/react/Marquee';
import { articleSchema, videoObjectSchema } from '~/lib/seo';

const opEds = await getCollection('opEds');
const tv = await getCollection('tv');

const items: ThoughtItem[] = [
  ...opEds.map((e) => ({
    kind: 'op-ed' as const,
    slug: e.id,
    title: e.data.title,
    outlet: e.data.outlet,
    publishedAt: e.data.publishedAt.toISOString(),
    teaser: e.data.teaser,
    pullQuote: e.data.pullQuote,
    externalUrl: e.data.externalUrl,
    tags: e.data.tags,
    featured: e.data.featured,
  })),
  ...tv.map((e) => ({
    kind: 'tv' as const,
    slug: e.id,
    title: e.data.title,
    network: e.data.network,
    program: e.data.program,
    host: e.data.host,
    airedAt: e.data.airedAt.toISOString(),
    duration: e.data.duration,
    teaser: e.data.teaser,
    externalUrl: e.data.externalUrl,
  })),
];

const jsonLd = [
  ...opEds.map((e) =>
    articleSchema({
      title: e.data.title,
      description: e.data.teaser,
      publishedAt: e.data.publishedAt,
      url: e.data.externalUrl,
      publisher: e.data.outlet,
    }),
  ),
  ...tv.map((e) =>
    videoObjectSchema({
      name: e.data.title,
      description: e.data.teaser,
      uploadDate: e.data.airedAt,
      duration: e.data.duration,
      url: e.data.externalUrl,
    }),
  ),
];
---

<BaseLayout
  title="Thought Leadership"
  description="Selected op-eds and television commentary by Reyad Hasnain on ICT policy, telecom regulation, mobile financial services, and the digital economy — across The Daily Star, The Financial Express, Daily Sun, Dhaka Tribune, ETV, Channel 24, and 71 TV."
  path="/thought-leadership"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Thought Leadership', href: '/thought-leadership' },
  ]}
  jsonLd={jsonLd}
>
  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="page-x relative overflow-hidden pt-32 pb-16 md:pt-40">
    <div class="aurora opacity-60"></div>

    <div class="relative mx-auto max-w-7xl grid items-center gap-12 md:grid-cols-12">
      <div class="md:col-span-7">
        <span class="enter inline-flex items-center gap-2 rounded-full border border-[var(--border-hair)] bg-[var(--bg-glass)] px-3 py-1 text-xs font-medium uppercase tracking-widest text-[var(--accent-cyan)] backdrop-blur">
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--accent-cyan)]"></span>
          Thought Leadership
        </span>
        <h1 class="enter mt-6 text-balance font-sans text-5xl font-semibold leading-[0.95] tracking-tight md:text-6xl lg:text-7xl">
          Twelve years on the
          <span class="font-serif italic text-gradient">policy page.</span>
        </h1>
        <p class="enter mt-8 max-w-2xl text-pretty text-[var(--text-lead)] leading-relaxed text-[var(--text-muted)]">
          Op-eds in The Daily Star, The Financial Express, Daily Sun, and Dhaka Tribune. Television commentary on Channel 24, ETV, Independent TV, and 71 TV. Filter, search, and read the originals.
        </p>
      </div>

      <div class="md:col-span-5">
        <div class="glass border-gradient relative overflow-hidden rounded-3xl p-8">
          <div aria-hidden class="pointer-events-none absolute -right-10 -top-10 h-44 w-44 rounded-full bg-[var(--accent-cyan-soft)] blur-3xl"></div>
          <p class="font-mono text-xs uppercase tracking-widest text-[var(--accent-cyan)]">
            Selected dispatches
          </p>
          <p class="mt-3 font-serif text-3xl italic leading-tight text-[var(--text-primary)]">
            "ICT and IT-enabled services can be the next RMG for Bangladesh."
          </p>
          <p class="mt-4 text-xs text-[var(--text-muted)]">
            — From an op-ed in <span class="text-[var(--text-primary)]">Daily Sun</span>, May 2025.
          </p>

          <div class="mt-6 grid grid-cols-3 gap-3 border-t border-[var(--border-hair)] pt-5">
            <div>
              <div class="font-mono text-2xl font-semibold text-[var(--text-primary)]">6</div>
              <div class="text-[10px] uppercase tracking-widest text-[var(--text-muted)]">Op-eds</div>
            </div>
            <div>
              <div class="font-mono text-2xl font-semibold text-[var(--text-primary)]">2</div>
              <div class="text-[10px] uppercase tracking-widest text-[var(--text-muted)]">TV interviews</div>
            </div>
            <div>
              <div class="font-mono text-2xl font-semibold text-[var(--text-primary)]">8</div>
              <div class="text-[10px] uppercase tracking-widest text-[var(--text-muted)]">Outlets</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── OUTLETS MARQUEE ─────────────────────────────────────────── -->
  <section class="border-y border-[var(--border-hair)] bg-[var(--bg-elevated)]/30 backdrop-blur">
    <div class="page-x mx-auto max-w-7xl">
      <Marquee client:visible items={[...OUTLETS]} speed={50} />
    </div>
  </section>

  <!-- ── GRID ─────────────────────────────────────────────────────── -->
  <Section eyebrow="Articles & appearances">
    <FilterableThoughtGrid client:visible items={items} />
  </Section>
</BaseLayout>
