---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/astro/Section.astro';
import OpEdCard from '~/components/astro/OpEdCard.astro';
import HeroBackdrop from '~/components/astro/HeroBackdrop.astro';
import LogoMarquee from '~/components/astro/LogoMarquee.astro';
import OutletLogos from '~/components/astro/OutletLogos.astro';
import StatCounter from '~/components/react/StatCounter';
import PillarsScrollLock from '~/components/react/PillarsScrollLock';
import QuoteRotator from '~/components/react/QuoteRotator';
import MagneticButton from '~/components/react/MagneticButton';
import {
  ArrowRight,
  Sparkles,
  Quote as QuoteIcon,
  Newspaper,
  ArrowUpRight,
  MapPin,
} from 'lucide-react';
import { PERSON, STATS, OUTLETS, PRESS_QUOTES } from '~/data/site';

const opEds = (await getCollection('opEds')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const featuredOpEds = opEds.filter((e) => e.data.featured).slice(0, 3);
const heroOpEd = featuredOpEds[0] ?? opEds[0];
const sideOpEds = featuredOpEds.slice(1, 3);

// Press coverage / news entries — about Smart Lab + Reyad, not authored by him.
const news = (await getCollection('news')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
const latestNews = news.slice(0, 4);
---

<BaseLayout
  title="Reyad Hasnain"
  description={PERSON.shortBio}
  path="/"
  type="profile"
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'ProfilePage',
      mainEntity: { '@id': `${import.meta.env.PUBLIC_SITE_URL ?? 'https://reyadhasnain.com'}/#person` },
    },
  ]}
>
  <!-- ╔══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║  HERO  — animated SVG backdrop, asymmetric layout, working CTAs  ║ -->
  <!-- ╚══════════════════════════════════════════════════════════════════╝ -->
  <section class="relative isolate overflow-hidden pt-28 md:pt-36 lg:pt-40">
    <HeroBackdrop />

    <div class="page-x relative mx-auto max-w-7xl pb-20 md:pb-32">
      <div class="grid items-center gap-12 lg:grid-cols-12 lg:items-start lg:gap-16">
        <!-- LEFT — Content -->
        <div class="lg:col-span-7" style="perspective: 1500px;">
          <!-- Status pill — fades in first -->
          <div class="fade-up inline-flex items-center gap-2 rounded-full border border-[var(--border-hair)] bg-[var(--bg-glass)] px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-[var(--brand)] backdrop-blur-md" style="--d:0s">
            <span class="pulse-dot"></span>
            <span>ICT Policy Advocate</span>
            <span class="text-[var(--text-faint)]">·</span>
            <span class="text-[var(--text-muted)]">Smart Lab Bangladesh</span>
          </div>

          <!-- Headline — flips in word by word -->
          <h1 class="mt-6 font-sans text-5xl font-semibold leading-[0.95] tracking-tight md:text-6xl lg:text-[5.5rem]" style="perspective: 1500px;">
            <span class="block">
              <span class="flip-in" style="--d:0.15s">Reyad</span>
            </span>
            <span class="block">
              <span class="flip-in text-gradient font-serif italic" style="--d:0.30s">Hasnain</span><span class="flip-in" style="--d:0.45s">.</span>
            </span>
          </h1>

          <!-- Tagline — slides up line by line -->
          <div class="mt-5 max-w-xl text-balance font-sans text-2xl font-semibold leading-[1.15] tracking-tight text-[var(--text-primary)] md:text-3xl">
            <span class="tagline-line" style="--d:0.55s">Telecom strategist.</span>
            <span class="tagline-line" style="--d:0.65s">Digital economy thought leader.</span>
            <span class="tagline-line" style="--d:0.75s">
              <span class="text-gradient font-serif italic">Public voice.</span>
            </span>
          </div>

          <!-- Bio — fades up after tagline -->
          <p class="fade-up mt-8 max-w-xl text-pretty text-[var(--text-lead)] leading-relaxed text-[var(--text-muted)]" style="--d:0.90s">
            Two decades of building telecoms and arguing the policy that surrounds them — across Asia, Africa, Europe, and North America. Today, making the case that
            <span class="font-medium text-[var(--text-primary)]">ICT can be the next RMG for Bangladesh</span>.
          </p>

          <!-- CTAs — fade up last -->
          <div class="fade-up mt-10 flex flex-wrap items-center gap-3" style="--d:1.05s">
            <a
              href="/thought-leadership"
              class="group relative inline-flex h-14 items-center gap-2 overflow-hidden rounded-full px-7 text-base font-medium text-white shadow-[0_15px_40px_-15px_var(--brand)] transition-all hover:-translate-y-0.5 hover:shadow-[0_25px_50px_-15px_var(--brand)]"
              style="background: var(--brand-gradient);"
            >
              Read his policy thinking
              <ArrowRight className="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
            </a>
            <a
              href="/about"
              class="group inline-flex h-14 items-center gap-2 rounded-full border border-[var(--border-hair)] bg-[var(--bg-glass)] px-7 text-base font-medium text-[var(--text-primary)] backdrop-blur-md transition-all hover:-translate-y-0.5 hover:border-[var(--border-bright)] hover:bg-[var(--bg-elevated)]"
            >
              Meet Reyad
            </a>
          </div>

        </div>

        <!-- RIGHT — Portrait + floating cards -->
        <div class="relative lg:col-span-5">
          <!-- Decorative glow -->
          <div
            aria-hidden="true"
            class="absolute -inset-8 -z-10 bg-[radial-gradient(circle_at_50%_30%,var(--brand-soft),transparent_60%)] blur-2xl"
          ></div>

          <!-- Frame -->
          <div class="tilt-in relative mx-auto aspect-[4/5] w-full max-w-[28rem]" style="--d:0.30s">
            <!-- Decorative corner brackets -->
            <span aria-hidden class="absolute -left-3 -top-3 h-8 w-8 border-l-2 border-t-2 border-[var(--brand)]"></span>
            <span aria-hidden class="absolute -right-3 -top-3 h-8 w-8 border-r-2 border-t-2 border-[var(--accent-gold)]"></span>
            <span aria-hidden class="absolute -bottom-3 -left-3 h-8 w-8 border-b-2 border-l-2 border-[var(--accent-gold)]"></span>
            <span aria-hidden class="absolute -bottom-3 -right-3 h-8 w-8 border-b-2 border-r-2 border-[var(--brand)]"></span>

            <div class="relative h-full w-full overflow-hidden rounded-3xl border border-[var(--border-hair)] shadow-[0_40px_100px_-25px_rgba(0,0,0,0.7)]">
              <img
                src="/images/riyadvai.jpg"
                alt={`${PERSON.fullName} — portrait`}
                width="560"
                height="700"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="h-full w-full object-cover"
                transition:name="reyad-headshot"
              />
              <div
                aria-hidden
                class="absolute inset-0 bg-gradient-to-t from-[var(--bg-base)]/85 via-[var(--bg-base)]/10 to-transparent"
              ></div>
              <div class="absolute bottom-5 left-5 right-5 flex items-center justify-between gap-2 text-xs font-medium text-[var(--text-primary)]">
                <span class="inline-flex items-center gap-2 rounded-full border border-[var(--border-bright)] bg-[var(--bg-base)]/60 px-3 py-1.5 backdrop-blur-md">
                  <span class="pulse-dot"></span>
                  MD · Smart Lab Bangladesh
                </span>
                <span class="inline-flex items-center gap-1.5 rounded-full border border-[var(--border-bright)] bg-[var(--bg-base)]/60 px-3 py-1.5 backdrop-blur-md">
                  <MapPin className="h-3 w-3 text-[var(--brand)]" />
                  Dhaka
                </span>
              </div>
            </div>
          </div>

          <!-- Floating card 1: tagline -->
          <div class="fade-up pointer-events-none absolute -bottom-6 -left-2 max-w-[15rem] rounded-2xl border border-[var(--border-hair)] bg-[var(--bg-elevated)]/85 p-4 shadow-2xl backdrop-blur-md md:-left-8 lg:-bottom-8" style="--d:0.95s">
            <div class="flex items-center gap-2 text-[10px] font-medium uppercase tracking-widest text-[var(--accent-gold)]">
              <Sparkles className="h-3 w-3" />
              Track record
            </div>
            <p class="mt-2 font-serif text-base italic leading-snug text-[var(--text-primary)]">
              "€11.2M+ in negotiated telecom deals across two continents."
            </p>
          </div>

          <!-- Floating card 2: latest news / momentum signal -->
          <a
            href="/thought-leadership"
            class="fade-up group absolute -right-2 -top-2 max-w-[14rem] rounded-2xl border border-[var(--border-hair)] bg-[var(--bg-elevated)]/90 p-4 shadow-2xl backdrop-blur-md transition-transform hover:-translate-y-0.5 md:-right-6 lg:-top-4"
            style="--d:1.1s"
          >
            <div class="flex items-center gap-2 text-[10px] font-medium uppercase tracking-widest text-[var(--brand)]">
              <span class="pulse-dot"></span>
              Just announced
            </div>
            <p class="mt-2 font-serif text-lg italic leading-snug text-[var(--text-primary)]">
              Smart Lab crosses into <span class="font-semibold not-italic">Nepal</span>.
            </p>
          </a>
        </div>
      </div>

      <!-- ── FULL-WIDTH STATS STRIP ─────────────────────────────────── -->
      <div class="mt-16 grid grid-cols-2 gap-6 border-t border-[var(--border-hair)] pt-10 md:mt-24 md:grid-cols-4 md:gap-8 md:pt-12 lg:gap-12">
        {STATS.map((s) => (
          <div class="flex flex-col gap-1.5">
            <StatCounter client:visible value={s.value} label={s.label} sub={s.sub} />
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="pointer-events-none absolute bottom-6 left-1/2 -translate-x-1/2">
      <div class="flex flex-col items-center gap-2 text-[10px] font-medium uppercase tracking-widest text-[var(--text-faint)]">
        <span>Scroll</span>
        <span class="h-8 w-px animate-pulse bg-gradient-to-b from-[var(--brand)] to-transparent"></span>
      </div>
    </div>
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║  OUTLETS MARQUEE — real publication wordmarks                    ║ -->
  <!-- ╚══════════════════════════════════════════════════════════════════╝ -->
  <section class="relative border-y border-[var(--border-hair)] py-10">
    <div class="page-x mx-auto max-w-7xl">
      <p class="mb-6 text-center text-xs font-medium uppercase tracking-[0.25em] text-[var(--text-faint)]">
        Featured · quoted · in conversation with
      </p>
      <LogoMarquee items={OUTLETS} speed={50} />
    </div>
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║  WHAT REYAD DOES — three pillars, scroll-locked                  ║ -->
  <!-- ╚══════════════════════════════════════════════════════════════════╝ -->
  <section class="relative">
    <div class="page-x mx-auto max-w-7xl pt-24 md:pt-32">
      <header class="mx-auto mb-8 flex max-w-3xl flex-col gap-5 text-center">
        <span class="enter inline-flex items-center gap-2 self-center rounded-full border border-[var(--border-hair)] bg-[var(--bg-glass)] px-3 py-1 text-xs font-medium uppercase tracking-widest text-[var(--brand)] backdrop-blur">
          <Sparkles className="h-3 w-3" />
          What Reyad does
        </span>
        <h2 class="enter text-balance text-[var(--text-headline)] font-semibold tracking-tight">
          Three pillars,
          <span class="text-gradient font-serif italic">one body of work.</span>
        </h2>
        <p class="enter text-pretty text-[var(--text-lead)] leading-relaxed text-[var(--text-muted)]">
          Twenty years of operating telecom businesses in real emerging markets, twelve years of public commentary on the policy that surrounds them, and an active executive role at the heart of Bangladesh's ICT sector — three reinforcing strands of the same argument.
        </p>
      </header>
    </div>

    <PillarsScrollLock client:visible />
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║  IN HIS OWN WORDS  — quote rotator with imagery                  ║ -->
  <!-- ╚══════════════════════════════════════════════════════════════════╝ -->
  <section class="relative overflow-hidden">
    <div class="page-x section-y mx-auto max-w-7xl">
      <div class="grid gap-12 md:grid-cols-12 md:items-center">
        <!-- Left: image collage -->
        <div class="relative md:col-span-5">
          <div class="relative aspect-square w-full overflow-hidden rounded-3xl border border-[var(--border-hair)]">
            <img
              src="/images/hero/network.jpg"
              alt="Network infrastructure abstract"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
            <div aria-hidden class="absolute inset-0 bg-gradient-to-tr from-[var(--bg-base)]/90 via-transparent to-[var(--brand-soft)]"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <p class="font-mono text-xs uppercase tracking-widest text-[var(--brand)]">2025</p>
              <p class="mt-2 font-serif text-2xl italic leading-tight text-[var(--text-primary)]">
                "ICT and IT-enabled services can be the next RMG for Bangladesh."
              </p>
              <p class="mt-3 text-xs text-[var(--text-muted)]">— Op-Ed, Daily Sun</p>
            </div>
          </div>

          <!-- Floating mini-card -->
          <div class="absolute -bottom-6 -right-4 max-w-[14rem] rounded-2xl border border-[var(--border-hair)] bg-[var(--bg-elevated)]/90 p-4 shadow-2xl backdrop-blur-md">
            <div class="flex items-center gap-2 text-[10px] font-medium uppercase tracking-widest text-[var(--accent-gold)]">
              <Newspaper className="h-3 w-3" />
              Twelve years
            </div>
            <p class="mt-2 text-sm leading-snug text-[var(--text-primary)]">
              On the policy page of Bangladesh's leading dailies — since 2013.
            </p>
          </div>
        </div>

        <!-- Right: rotating quote -->
        <div class="md:col-span-7">
          <span class="enter inline-flex items-center gap-2 rounded-full border border-[var(--border-hair)] bg-[var(--bg-glass)] px-3 py-1 text-xs font-medium uppercase tracking-widest text-[var(--accent-gold)] backdrop-blur">
            <QuoteIcon className="h-3 w-3" />
            In his own words
          </span>

          <h2 class="enter mt-5 text-balance text-[var(--text-headline)] font-semibold tracking-tight">
            Twenty years of arguments,
            <span class="font-serif italic text-gradient">on the record.</span>
          </h2>

          <p class="enter mt-5 max-w-xl text-pretty text-[var(--text-lead)] leading-relaxed text-[var(--text-muted)]">
            The convictions that run through the writing — public, dated, in print, traceable to the moment they were made.
          </p>

          <div class="mt-10">
            <QuoteRotator client:visible quotes={[...PRESS_QUOTES]} intervalMs={6500} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║  PRESS COVERAGE / NEWS  — Smart Lab in the headlines             ║ -->
  <!-- ╚══════════════════════════════════════════════════════════════════╝ -->
  <Section
    eyebrow="In the news"
    title="Smart Lab Bangladesh, in the headlines."
    intro="Press coverage of Smart Lab's regional expansion and Reyad Hasnain's public work — across Bangladesh's leading dailies."
  >
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {latestNews.map((item, i) => (
        <a
          href={item.data.externalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="glass border-gradient group relative flex flex-col gap-0 overflow-hidden rounded-3xl transition-all hover:-translate-y-1 hover:shadow-2xl"
        >
          {item.data.image && (
            <div class="relative aspect-[16/10] w-full overflow-hidden">
              <img
                src={item.data.image}
                alt=""
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div
                aria-hidden
                class="absolute inset-0 bg-gradient-to-t from-[var(--bg-elevated)] via-[var(--bg-elevated)]/30 to-transparent"
              ></div>
              <span class="absolute left-3 top-3 inline-flex items-center gap-1 rounded-full border border-[var(--accent-gold)]/40 bg-[var(--accent-gold-soft)] px-2.5 py-1 text-[10px] font-medium uppercase tracking-widest text-[var(--accent-gold)] backdrop-blur">
                News
              </span>
            </div>
          )}
          <div class="flex flex-1 flex-col gap-3 p-5">
            <div class="flex items-center justify-between">
              <OutletLogos name={item.data.outlet} className="h-5 w-auto text-[var(--text-primary)]" />
              <time
                class="font-mono text-[10px] uppercase tracking-widest text-[var(--text-faint)]"
                datetime={item.data.publishedAt.toISOString()}
              >
                {new Date(item.data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
              </time>
            </div>
            <h3 class="font-serif text-lg italic leading-tight text-[var(--text-primary)] transition-colors group-hover:text-[var(--brand)]">
              {item.data.title}
            </h3>
            <p class="text-sm leading-relaxed text-[var(--text-muted)] line-clamp-3">
              {item.data.teaser}
            </p>
            <span class="mt-auto inline-flex items-center gap-1 pt-2 text-xs font-medium text-[var(--text-muted)] transition-all group-hover:translate-x-0.5 group-hover:text-[var(--brand)]">
              Read at {item.data.outlet}
              <ArrowUpRight className="h-3 w-3 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <!-- ╔══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║  FEATURED OP-EDS — bento, real outlet badges                     ║ -->
  <!-- ╚══════════════════════════════════════════════════════════════════╝ -->
  <Section
    eyebrow="Thought leadership"
    title="Selected op-eds & commentary"
    intro="Twelve years of writing on Bangladesh's ICT, telecom, and digital-economy policy — selected from leading national dailies."
  >
    <div class="grid gap-6 md:grid-cols-12">
      {heroOpEd && (
        <div class="md:col-span-7">
          <article class="glass border-gradient group relative flex h-full min-h-[28rem] flex-col gap-5 overflow-hidden rounded-3xl p-8 transition-transform hover:-translate-y-1 md:p-12">
            <a
              href={heroOpEd.data.externalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="absolute inset-0 z-10"
              aria-label={`Read "${heroOpEd.data.title}" at ${heroOpEd.data.outlet}`}
            ></a>

            <div
              aria-hidden
              class="pointer-events-none absolute -right-32 -top-32 h-72 w-72 rounded-full bg-[var(--brand-soft)] blur-3xl transition-opacity group-hover:opacity-100"
              style="opacity: 0.5"
            ></div>

            <div class="flex items-center justify-between">
              <OutletLogos name={heroOpEd.data.outlet} className="h-7 w-auto text-[var(--brand)]" />
              <time class="font-mono text-xs text-[var(--text-faint)]">
                {new Date(heroOpEd.data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
              </time>
            </div>

            <h3 class="font-serif text-balance text-3xl italic leading-tight text-[var(--text-primary)] transition-colors group-hover:text-[var(--brand)] md:text-5xl">
              {heroOpEd.data.title}
            </h3>

            {heroOpEd.data.pullQuote && (
              <blockquote class="border-l-2 border-[var(--brand)] pl-4 font-serif text-lg italic text-[var(--brand)]">
                "{heroOpEd.data.pullQuote}"
              </blockquote>
            )}

            <p class="text-pretty leading-relaxed text-[var(--text-muted)]">
              {heroOpEd.data.teaser}
            </p>

            <div class="mt-auto flex items-center justify-between border-t border-[var(--border-hair)] pt-6">
              <span class="font-mono text-xs text-[var(--text-faint)]">
                Featured · {heroOpEd.data.outlet}
              </span>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-[var(--text-muted)] transition-all group-hover:translate-x-0.5 group-hover:text-[var(--brand)]">
                Read full piece
                <ArrowUpRight className="h-4 w-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
              </span>
            </div>
          </article>
        </div>
      )}

      <div class="grid gap-6 md:col-span-5">
        {sideOpEds.map((e) => (
          <OpEdCard entry={e} size="md" />
        ))}
      </div>
    </div>

    <div class="mt-12 flex justify-center">
      <MagneticButton client:visible href="/thought-leadership" variant="secondary" size="lg">
        View all 8 publications
        <ArrowRight className="h-4 w-4" />
      </MagneticButton>
    </div>
  </Section>

  <!-- ╔══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║  POLICY PRIORITIES TEASER  — driven from collection              ║ -->
  <!-- ╚══════════════════════════════════════════════════════════════════╝ -->
  <Section
    eyebrow="Policy priorities"
    title="Five reforms for Bangladesh's ICT industry."
    intro="The argument behind two decades of writing and operating: ICT and IT-enabled services can be the next RMG. Here is what regulation has to look like for that to happen."
  >
    <div class="grid gap-4 md:grid-cols-5">
      {[
        { n: '01', t: 'Regulatory reform', s: 'For ICT exports' },
        { n: '02', t: 'Digital inclusion', s: 'Rural broadband' },
        { n: '03', t: 'Youth skills', s: 'ICT workforce' },
        { n: '04', t: 'AI & fintech', s: 'Emerging tech' },
        { n: '05', t: 'Sovereignty', s: 'Data protection' },
      ].map((p, i) => (
        <a
          href="/policy"
          class="group glass border-gradient relative flex flex-col gap-3 rounded-2xl p-5 transition-transform hover:-translate-y-1"
        >
          <span class="font-mono text-xs text-[var(--brand)]">{p.n}</span>
          <h3 class="font-serif text-2xl italic leading-tight text-[var(--text-primary)] transition-colors group-hover:text-[var(--brand)]">
            {p.t}
          </h3>
          <span class="text-xs uppercase tracking-widest text-[var(--text-muted)]">{p.s}</span>
          <ArrowUpRight class="absolute right-4 top-4 h-4 w-4 text-[var(--text-faint)] transition-all group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-[var(--brand)]" />
        </a>
      ))}
    </div>
  </Section>

  <!-- ╔══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║  CTA STRIP  — speak / advise / comment                           ║ -->
  <!-- ╚══════════════════════════════════════════════════════════════════╝ -->
  <section class="page-x relative my-24">
    <div class="relative mx-auto max-w-7xl overflow-hidden rounded-3xl border border-[var(--border-hair)]">
      <!-- Background image -->
      <img
        src="/images/about/bangladesh.jpg"
        alt=""
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover opacity-25"
      />
      <div aria-hidden class="absolute inset-0 bg-gradient-to-r from-[var(--bg-base)] via-[var(--bg-base)]/80 to-transparent"></div>
      <div class="aurora opacity-100"></div>

      <div class="relative grid gap-8 p-10 md:grid-cols-12 md:items-end md:p-16 lg:p-20">
        <div class="md:col-span-8">
